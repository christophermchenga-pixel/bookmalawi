# Server
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/bookmalawi
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bookmalawi
DB_USER=postgres
DB_PASSWORD=password

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# OTP
OTP_EXPIRE=600
OTP_LENGTH=6

# Payment Gateways
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret

PAYCHANG_API_KEY=your_paychang_api_key
PAYCHANG_MERCHANT_ID=your_merchant_id

AIRTEL_API_KEY=your_airtel_api_key
AIRTEL_API_URL=https://api.airtel.co.mw

TNM_API_KEY=your_tnm_api_key
TNM_API_URL=https://api.tnm.co.mw

# Email Service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@bookmalawi.com

# SMS Service
AFRICAS_TALKING_API_KEY=your_africas_talking_api_key
AFRICAS_TALKING_USERNAME=your_africas_talking_username
AFRICAS_TALKING_FROM=BookMalawi

# Supabase
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key
SUPABASE_BUCKET_NAME=bookmalawi-files

# Commission Settings
PLATFORM_COMMISSION_PERCENTAGE=2.5
PARTNER_SETTLEMENT_PERIOD=weekly
TRANSACTION_DELETE_MONTHS=3

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:8081

# Logging
LOG_LEVEL=debug
